# -----------------------------------------------------------------------------
# Docker Compose Variables (Used in docker-compose.yml)
# -----------------------------------------------------------------------------
POSTGRES_USER=feedback_user
POSTGRES_PASSWORD=feedback_pass
POSTGRES_DB=feedback_db

# -----------------------------------------------------------------------------
# API Variables (apps/api/.env or via Docker)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://feedback_user:feedback_pass@postgres:5432/feedback_db?schema=public"
REDIS_URL="redis://redis:6379"
JWT_SECRET="supersecretjwtkey_changeme_in_production"
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Web Variables (apps/web/.env)
# -----------------------------------------------------------------------------
VITE_API_URL="http://localhost:5000"
