generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Feedback {
  id         String   @id @default(uuid())
  name       String?
  email      String?
  category   Category
  comment    String
  rating     Int?
  status     Status   @default(OPEN)
  createdAt  DateTime @default(now())

  @@map("feedbacks")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())

  @@map("users")
}

enum Category {
  PRODUCT
  SERVICE
  SUPPORT
  BILLING
  OTHER
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
}
